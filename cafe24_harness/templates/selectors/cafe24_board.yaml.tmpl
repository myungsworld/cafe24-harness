# DOM/콘텐츠 패턴만 (URL은 config.yaml + 코어가 계산). 깨지면 여기만 수정.

# 게시/미게시 토글: 네이버페이 비회원 후기는 기본 '미게시' → 이 버튼 눌러야 노출됨.
#   <a id="ePostId_{no}" onclick="setPost('{board}','{no}')">게시함</a>  (버튼 있으면 = 미게시)
post_toggle_id_prefix: "ePostId_"

# 비회원/외부연동(네이버페이) 후기 식별 키워드
writer_keyword: 네이버 페이 구매자

# 글의 공개/노출 상태를 나타낼 수 있는 텍스트 후보
status_keywords:
  - 공개
  - 비공개
  - 노출
  - 미노출
  - 전시
  - 미전시
  - 비밀
  - 승인
  - 대기

# 특정 후기를 화면에서 찾기 위한 식별 키워드 (프로젝트별 — 필요 시 추가)
target_reviews: []
